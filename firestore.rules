rules_version = '2';

// Worn Gundidj CMS — Firestore security rules
// Deploy: Firebase Console → Firestore Database → Rules → paste → Publish
// (or `firebase deploy --only firestore:rules` if using the CLI).
//
// Baseline posture: only signed-in staff (email/password accounts) can access
// team data. This matches what is currently live (verified: anonymous = 403).
//
// NOTE on least-privilege (audit findings #2/#3): true per-worker / per-role
// restriction and immutable case notes require staff roles to live in Firebase
// custom claims (set by a trusted Cloud Function), plus server Timestamps on
// notes. That is a separate hardening project — see the commented block below
// for the target shape. Do NOT enable it until the app writes custom claims and
// server timestamps, or staff will be locked out.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // All CMS data lives under teams/{teamId}/**
    match /teams/{teamId}/{document=**} {
      allow read, write: if signedIn();
    }
  }
}

