rules_version = '2';

// Worn Gundidj CMS — Cloud Storage security rules
// Deploy: Firebase Console → Storage → Rules → paste → Publish
// (or `firebase deploy --only storage` if using the CLI).
//
// Baseline posture: only signed-in staff (email/password accounts) can read or
// write team files. This matches what is currently live (verified: anonymous =
// 403). Client attachments (proof of income, COA, pre-approval) and resource
// files live under teams/{teamId}/**.
//
// Hardening notes (audit findings #2/#4):
//   - A per-worker / per-role restriction requires staff roles in Firebase
//     custom claims (set by a trusted Cloud Function). See the commented target
//     block below — do NOT enable until the app writes custom claims.
//   - The size/type limits below are safe to keep enabled now: they cap uploads
//     at 25 MB and only block obviously executable content types.

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() { return request.auth != null; }
    function underLimit() { return request.resource.size < 25 * 1024 * 1024; }

    // All CMS files live under teams/{teamId}/**
    match /teams/{teamId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && underLimit();
    }
  }
}

